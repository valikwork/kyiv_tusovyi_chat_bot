# Copy this file to .env for local development
# DO NOT commit .env to version control!

# Required - Your bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Required - Your target chat/group ID
CHAT_ID=-1002329866894

# Required - Your admin user ID
ADMIN_USER_ID=274157532

# Optional - Rate limiting in minutes (default: 5)
RATE_LIMIT_MINUTES=5

# Optional - Maximum message length (default: 4000)
MAX_MESSAGE_LENGTH=4000

# Optional - Port for Railway (default: 5000)
PORT=5000